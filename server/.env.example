# # Server
# PORT=3000

# # Database
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>

# # Authentication
# SECRET_KEY=your_jwt_or_app_secret_here

# # Client origin (comma-separated for CORS)
# CLIENT_URL=http://localhost:5173
# CLIENT_URLS=http://localhost:5173,https://your-app.web.app

# # Email (choose one provider)
# RESEND_API_KEY=your_resend_api_key
# GMAIL_USER=your_email@gmail.com
# GMAIL_APP_PASS=your_gmail_app_password

# # Admin
# ADMIN_EMAIL=admin@example.com

# # Firm branding
# FIRM_NAME=LexSchedule

# # Reminders / Emails
# REMINDERS_DISABLED=0
# REMINDER_BATCH_LIMIT=100
# EMAILS_DISABLED=0

# # Environment
# NODE_ENV=development
# COOKIE_SECURE=0
# COOKIE_SAMESITE=lax

# # Internal cron (set false in production when using Cloud Scheduler)
# USE_INTERNAL_CRON=true

# # Cloud Scheduler secret (shared between Cloud Scheduler and server)
# CRON_SECRET=your-secret-here

# # Sentry error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@ingest.sentry.io/...

